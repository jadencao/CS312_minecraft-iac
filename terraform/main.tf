# ----------------------------------------------------------------------------
# main.tf — The actual infrastructure: network, firewall, SSH key, and the
# EC2 instance that will run the Minecraft server.
#
# Terraform is declarative: this file DESCRIBES the desired end state, and
# `terraform apply` figures out what to create/change to make reality match.
# Running apply twice in a row changes nothing the second time (idempotent).
# ----------------------------------------------------------------------------

# ---------- AMI lookup: latest Ubuntu 24.04 LTS (x86_64) ----------
# A "data" block READS information instead of creating anything.
# This asks AWS for the newest official Ubuntu 24.04 image so we never
# hardcode an AMI ID that goes stale.
data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"] # Canonical's official AWS account ID

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd-gp3/ubuntu-noble-24.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# ---------- Networking ----------
# A VPC is our own private slice of the AWS network (like a private property).
# 10.0.0.0/16 gives us 65,536 private IP addresses to carve up.
resource "aws_vpc" "main" {
  cidr_block           = "10.0.0.0/16"
  enable_dns_support   = true # let instances resolve DNS names
  enable_dns_hostnames = true # give instances DNS hostnames

  tags = { Name = "${var.project_name}-vpc" }
}

# The internet gateway is the VPC's "front door" to the public internet.
# Without it, nothing inside the VPC can be reached from outside.
resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = { Name = "${var.project_name}-igw" }
}

# A subnet is a smaller section of the VPC where instances actually live.
# map_public_ip_on_launch gives instances a public IP automatically.
resource "aws_subnet" "public" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "10.0.1.0/24" # 256 addresses inside the VPC
  map_public_ip_on_launch = true

  tags = { Name = "${var.project_name}-public-subnet" }
}

# The route table is the subnet's "directions sign":
# "for any destination (0.0.0.0/0), go through the internet gateway."
# This is what makes the subnet a PUBLIC subnet.
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = { Name = "${var.project_name}-public-rt" }
}

# Attach the route table to the subnet (a table does nothing until associated).
resource "aws_route_table_association" "public" {
  subnet_id      = aws_subnet.public.id
  route_table_id = aws_route_table.public.id
}

# ---------- Security group ----------
# The security group is a stateful firewall around the instance.
# Only the ports listed here are reachable from outside:
#   22    -> SSH, used by Ansible to configure the machine
#   25565 -> the Minecraft server port, open to all players
resource "aws_security_group" "minecraft" {
  name        = "${var.project_name}-sg"
  description = "Allow SSH (Ansible) and Minecraft traffic"
  vpc_id      = aws_vpc.main.id

  ingress {
    description = "SSH for Ansible configuration"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Minecraft server port"
    from_port   = var.minecraft_port
    to_port     = var.minecraft_port
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  # Outbound: allow everything, so the server can download packages and the jar.
  egress {
    description = "Allow all outbound"
    from_port   = 0
    to_port     = 0
    protocol    = "-1" # -1 = all protocols
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = { Name = "${var.project_name}-sg" }
}

# ---------- SSH key (generated by Terraform, never committed to git) ----------
# Instead of creating a key pair by hand in the console, Terraform forges one:
#   1. tls_private_key generates a fresh 4096-bit RSA key in memory
#   2. aws_key_pair uploads the PUBLIC half to AWS for the instance
#   3. local_file saves the PRIVATE half next to the Ansible files (gitignored)
resource "tls_private_key" "ssh" {
  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "minecraft" {
  key_name   = "${var.project_name}-key"
  public_key = tls_private_key.ssh.public_key_openssh
}

resource "local_file" "private_key" {
  content         = tls_private_key.ssh.private_key_pem
  filename        = "${path.module}/../ansible/minecraft_key.pem"
  file_permission = "0600" # SSH refuses keys that other users can read
}

# ---------- EC2 instance ----------
# The virtual machine itself. Note what is NOT here: no user_data (banned by
# the assignment, and bad practice) — all configuration is done by Ansible.
resource "aws_instance" "minecraft" {
  ami                    = data.aws_ami.ubuntu.id # from the lookup above
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.public.id
  vpc_security_group_ids = [aws_security_group.minecraft.id]
  key_name               = aws_key_pair.minecraft.key_name

  root_block_device {
    volume_size = 15 # GiB — room for the OS, Java, and the world files
    volume_type = "gp3"
  }

  tags = { Name = "${var.project_name}-server" }
}

# ---------- Auto-generate the Ansible inventory ----------
# This is the hand-off between the two tools: once the instance exists,
# Terraform writes its public IP into ansible/inventory.ini. The IP changes
# on every rebuild, but Ansible never breaks because this file is regenerated.
resource "local_file" "ansible_inventory" {
  content  = <<-EOT
    [minecraft]
    ${aws_instance.minecraft.public_ip} ansible_user=ubuntu ansible_ssh_private_key_file=minecraft_key.pem
  EOT
  filename = "${path.module}/../ansible/inventory.ini"
}